{
  "name": "@sog-loader/core",
  "private": true,
  "version": "0.0.0",
  "description": ".sog Gaussian Splatting file loader package.",
  "author": {
    "name": "drumath2237",
    "url": "https://github.com/drumath2237"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drumath2237/sog-loader",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/drumath2237/sog-loader/issues"
  },
  "homepage": "https://github.com/drumath2237/sog-loader",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "sog",
    "3d gaussian splatting",
    "decoder"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "wasm:clear": "node ../../scripts/wasm_clear.mjs",
    "wasm:build": "pnpm wasm:clear && wasm-bindgen ../../target/wasm32-unknown-unknown/debug/sog_decoder_wasm.wasm --out-dir ./lib/wasm/ --target bundler",
    "check": "biome check",
    "check:write": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.0",
    "typescript": "~5.9.3",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^7.2.7",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
